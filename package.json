{
  "name": "mindvault",
  "private": true,
  "version": "0.1.0",
  "description": "Personalized AI Memory Architecture — A Context-Aware Knowledge System for Local and Cloud LLMs",
  "author": "Aashish",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "prepare": "husky",
    "lint": "eslint .",
    "format": "prettier --write .",
    "preflight": "node scripts/preflight.mjs",
    "preflight:fix": "node scripts/preflight.mjs --fix",
    "license-check": "license-checker-rseidelsohn --production --excludePrivate --onlyAllow \"MIT;ISC;BSD-3-Clause;BSD-2-Clause;Apache-2.0;Unlicense;MPL-2.0\" --summary",
    "test": "npx tsx scripts/test-frontend.ts",
    "test:ui": "vitest run",
    "test:all": "npm test && npm run test:ui"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-opener": "^2",
    "jsonrepair": "^3.14.0",
    "katex": "^0.17.0",
    "mafs": "^0.21.0",
    "mermaid": "^11.15.0",
    "plotly.js-dist-min": "^3.5.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@size-limit/preset-app": "^12.1.0",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vscode/ripgrep": "^1.17.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "license-checker-rseidelsohn": "^4.4.2",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "size-limit": "^12.1.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^7.3.5",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "@babel/core": "7.29.7",
    "dompurify": "3.4.11",
    "esbuild": "0.28.1",
    "js-yaml": "4.2.0"
  },
  "size-limit": [
    {
      "path": "dist/**/*.js",
      "limit": "3 MB"
    }
  ],
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
